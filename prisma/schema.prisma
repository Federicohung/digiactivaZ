// DigiActiva - Multi-tenant SaaS Platform
// Database Schema (PostgreSQL via Neon + Prisma)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("POSTGRES_URL_NONPOOLING")
}

// ─── Users & Auth ───
model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  passwordHash       String
  name               String
  role               String   @default("workspace_admin") // founder_admin | workspace_admin
  workspaceIds       Json     @default("[]") // JSON array of workspace IDs
  activeWorkspaceId  String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  workspaces         WorkspaceMember[]
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  role        String   @default("admin") // admin | member
  joinedAt    DateTime @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

// ─── Workspaces (Multi-tenant) ───
model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  plan        String   @default("essential") // essential | premium | elite | founder_full
  modules     Json     @default("{}") // { chat: true, whatsapp: true, crm: true, inbox: true, voice: false, copilot: false }
  integrations Json    @default("{}") // { whatsapp: { ... }, resend: { ... } }
  agentPrompts Json    @default("{}") // { web_chat: { ... }, whatsapp: { ... }, voice: { ... } }
  metaMensual  Json    @default("{}") // { meta: 0, periodo: "" }
  branding     Json    @default("{}") // { color, logo_url, nombre_negocio }
  onboardingCompleted Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     WorkspaceMember[]
  contacts    Contact[]
  timeline    TimelineEvent[]
  messages    Message[]
  chatSessions ChatSession[]
  conversations Conversation[]
  aiLogs      AiLog[]
}

// ─── CRM ───
model Contact {
  id              String   @id @default(cuid())
  workspaceId     String
  empresa         String?
  nombre          String
  telefono        String?
  email           String?
  nicho           String?
  fuente          String   @default("web_chat") // web_chat | whatsapp | manual | messenger | instagram | external
  etapa           String   @default("nuevo") // nuevo | contactado | calificado | propuesta | negociacion | cerrado
  valorMensual    Float    @default(0)
  probabilidadCierre Float @default(0)
  scoreIa         Float    @default(0)
  aiSummary       String?
  instagramId     String?
  messengerId     String?
  whatsappId      String?
  notas           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace       Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  timeline        TimelineEvent[]
  messages        Message[]
  conversations   Conversation[]
  chatSessions    ChatSession[]

  @@index([workspaceId])
  @@index([workspaceId, etapa])
}

model TimelineEvent {
  id          String   @id @default(cuid())
  workspaceId String
  contactId   String
  tipo        String   // nota | mensaje | llamada | etapa_cambiada | ai_summary | email | whatsapp
  descripcion String
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([workspaceId, contactId])
}

model Message {
  id             String   @id @default(cuid())
  workspaceId    String
  contactId      String
  channel        String   @default("web_chat") // web_chat | whatsapp | messenger | instagram | external
  direction      String   @default("inbound") // inbound | outbound
  content        String
  sessionId      String?
  conversationId String?
  metadata       Json     @default("{}")
  status         String   @default("delivered") // sent | delivered | read | failed
  createdAt      DateTime @default(now())

  workspace      Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact        Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([workspaceId, contactId])
  @@index([workspaceId, conversationId])
}

model ChatSession {
  id          String   @id @default(cuid())
  workspaceId String
  contactId   String?
  messages    Json     @default("[]") // JSON array of messages
  leadData    Json     @default("{}")
  source      String   @default("web_chat")
  status      String   @default("active") // active | closed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact     Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
}

model Conversation {
  id                String   @id @default(cuid())
  workspaceId       String
  contactId         String
  channel           String   @default("web_chat")
  provider          String   @default("native") // native | composio
  status            String   @default("open") // open | closed | archived
  unreadCount       Int      @default(0)
  lastMessagePreview String?
  lastMessageAt     DateTime @default(now())
  assignedToUserId  String?
  tags              Json     @default("[]") // JSON array
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact           Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages          Message[]

  @@index([workspaceId])
  @@index([workspaceId, contactId])
  @@index([workspaceId, lastMessageAt])
}

model AiLog {
  id          String   @id @default(cuid())
  workspaceId String
  tipo        String   // summary | score | generate | priorities
  contactId   String?
  model       String   @default("gpt-4o-mini")
  tokens      Int      @default(0)
  contenido   String
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

// ─── Landing Page Leads ───
model Lead {
  id              String   @id @default(cuid())
  workspaceId     String   @default("default")
  nombre          String
  email           String
  telefono        String?
  servicioInteres String?
  createdAt       DateTime @default(now())

  @@index([workspaceId])
}

// ─── Composio Connections (Facebook & Instagram) ───
model ComposioConnection {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  toolkit     String   // facebook | instagram
  connected   Boolean  @default(false)
  accountId   String?  // FB/IG account ID
  accountName String?  // FB/IG page/account name
  metadata    Json     @default("{}") // Store any extra data from Composio
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([workspaceId, toolkit])
  @@index([workspaceId])
}

// ─── Global Settings ───
model GlobalSetting {
  id    String @id @default(cuid())
  key   String @unique
  value Json   @default("{}")
}

// ─── Niche Templates ───
model NicheTemplate {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  nicho       String
  prompts     Json     @default("{}")
  modules     Json     @default("{}")
  createdAt   DateTime @default(now())
}

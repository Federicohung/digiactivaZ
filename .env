# ─── Neon PostgreSQL (Vercel Integration) ───
# These env vars are set automatically by the Neon Vercel integration:
# POSTGRES_URL, POSTGRES_URL_NO_SSL, POSTGRES_HOST, PGUSER, PGPASSWORD, PGDATABASE
#
# For local development, copy your Neon connection string from:
# https://console.neon.tech → Project → Connection Details
POSTGRES_URL="postgresql://neondb_owner:placeholder@ep-placeholder.us-east-2.aws.neon.tech/neondb?sslmode=require"
POSTGRES_URL_NO_SSL="postgresql://neondb_owner:placeholder@ep-placeholder.us-east-2.aws.neon.tech/neondb"

# ─── Auth ───
JWT_SECRET="digiactiva-prod-secret-2025-change-me"

# ─── OpenAI ───
OPENAI_API_KEY=""
